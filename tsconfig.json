{
	"compilerOptions": {
		"target": "es2023",
		"module": "esnext",
		"lib": ["ES2023", "DOM"],
		"types": ["vite/client"],
		"skipLibCheck": true,

		/* Bundler mode */
		"moduleResolution": "bundler",
		"allowImportingTsExtensions": true,
		"verbatimModuleSyntax": true,
		"moduleDetection": "force",
		"noEmit": true,

		/* Paths */
		"paths": {
			"src/*": ["./src/*"]
		},

		/* Linting */
		"noUnusedLocals": true,
		"noUnusedParameters": true,
		"erasableSyntaxOnly": true,
		"noFallthroughCasesInSwitch": true
	},
	"include": ["./src/**/*", "./scripts/**/*", "vite.config.ts", "eslint.config.js"],
	"exclude": ["node_modules"]
}
